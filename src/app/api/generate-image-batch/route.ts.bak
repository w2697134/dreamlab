// 模型匹配检查函�?
const isModelMatch = (currentModel: string | null, targetModel: SDModel): boolean => {
  if (!currentModel) return false;
  const lowerCurrent = currentModel.toLowerCase();
  const targetName = targetModel.file.toLowerCase().replace('.safetensors', '');
  return lowerCurrent.includes(targetName);
};

// 延迟函数 - 降低API调用速率
const delay = (ms: number) => new Promise(resolve => setTimeout(resolve, ms));

// 本地存储路径
const LOCAL_STORAGE_PATH = path.join(process.cwd(), 'public', 'generated-images');

// 确保本地存储目录存在
function ensureLocalStorageDir(): void {
  if (!fs.existsSync(LOCAL_STORAGE_PATH)) {
    fs.mkdirSync(LOCAL_STORAGE_PATH, { recursive: true });
    console.log('[本地存储] 创建目录:', LOCAL_STORAGE_PATH);
  }
}

// 保存图片到本地（使用异步写入避免阻塞�?
async function saveImageLocal(base64Image: string, fileName: string): Promise<string> {
  ensureLocalStorageDir();
  
  const filePath = path.join(LOCAL_STORAGE_PATH, fileName);
  const imageBuffer = Buffer.from(base64Image, 'base64');
  
  // 使用异步写入避免阻塞事件循环
  await fs.promises.writeFile(filePath, imageBuffer);
  console.log('[本地存储] 图片已保�?', filePath);
  
  // 返回可访问的 URL
  return `/generated-images/${fileName}`;
}

// 并行保存多张图片
async function saveImagesParallel(
  images: Array<{ base64: string; fileName: string; index: number }>
): Promise<Map<number, string>> {
  const results = new Map<number, string>();
  
  await Promise.all(
    images.map(async ({ base64, fileName, index }) => {
      try {
        const url = await saveImageLocal(base64, fileName);
        results.set(index, url);
      } catch (error) {
        console.error(`[并行保存] 图片 ${index} 保存失败:`, error);
        throw error;
      }
    })
  );
  
  return results;
}

// 初始化存储（如果配置了环境变量则使用 S3，否则使用本地存储）
const storage = process.env.COZE_BUCKET_ENDPOINT_URL && process.env.COZE_BUCKET_NAME 
  ? new S3Storage({
      endpointUrl: process.env.COZE_BUCKET_ENDPOINT_URL,
      accessKey: "",
      secretKey: "",
      bucketName: process.env.COZE_BUCKET_NAME,
      region: "cn-beijing",
    })
  : null;

// 获取梦境会话历史
async function getDreamSessionHistory(sessionId: string, token: string) {
  if (!sessionId) return null;
  
  try {
    const client = getSupabaseClient(token);
    const { data: session, error } = await client
      .from("dream_sessions")
      .select("*")
      .eq("id", sessionId)
      .single();
    
    if (error || !session) {
      console.log('[会话] 未找到会�?', sessionId);
      return null;
    }
    
    return {
      prompt_history: session.prompt_history ? JSON.parse(session.prompt_history) : [],
      image_history: session.image_history ? JSON.parse(session.image_history) : [],
      latest_prompt: session.latest_prompt,
      image_count: session.image_count || 0,
    };
  } catch (error) {
    console.error('[会话] 获取会话历史失败:', error);
    return null;
  }
}

// 构建关联上下文（用于润色时保持图片间的连贯性）
function buildContextSummary(sessionHistory: {
  prompt_history: Array<{ prompt: string; imageUrl?: string; timestamp: number }>;
  image_history: string[];
  image_count: number;
}) {
  if (!sessionHistory || sessionHistory.prompt_history.length === 0) {
    return null;
  }
  
  // 提取之前的提示词作为上下�?
  const previousPrompts = sessionHistory.prompt_history.map((h, i) => 
    `【图${i + 1}�? ${h.prompt}`
  ).join('\n');
  
  return {
    summary: `这是梦境创作的延续。当前已生成 ${sessionHistory.image_count} 张图片。`,
    previousPrompts,
    previousImagesCount: sessionHistory.image_history.length,
  };
}

// 检�?SD API 是否可用
async function isSDAvailable(): Promise<boolean> {
  const available = await getAvailableInstances();
  return available.length > 0;
}

// 中文翻译成英文（用于 SD�?
async function translateToEnglish(chinesePrompt: string, customHeaders?: Record<string, string>): Promise<string> {
  try {
    const messages = [
      { 
        role: 'system' as const, 
        content: `你是一个专业的英文翻译助手。将用户输入的中文梦境描述精准翻译成英文，保留以下元素：
1. 核心画面描述（场景、人物、物品）
2. 光线氛围（dawn/morning/noon/dusk/night/midnight�?
3. 情绪基调（peaceful/mysterious/warm/melancholy/magical/lonely�?
4. 艺术风格关键词（如果提到�?
5. 视角描述（close/medium/far/bird's eye/worm's eye view�?
6. 【重�?- 自动识别角色名�?
   使用你的知识库自动识别角色名（动漫、游戏、影视角色）�?
   - 检测模式："国漫XXX"�?动漫XXX"�?日漫XXX"�?游戏XXX"�?XX角色"
   - 你认识的角色：保留英�?罗马音名�?+ 出处
   - 不认识的角色：保留拼�?+ 合理推测
   - 不要字面翻译角色名（小七≠little seven�?
   - 小七 -> Xiao Qi (Chinese anime character)
   - 小舞 -> Xiao Wu (Soul Land character)

翻译规则�?
- 只输出英文翻译，不要解释
- 保留中文中的意象和比喻，用英文重新表�?
- 添加适合的英文形容词增强画面�?
- 避免翻译括号内的技术性说明（�?电影级构�?等）
- 保持简洁，通常20-80个英文单�?
- 动漫角色用英�?罗马音表示，并注明角色来源以增强识别

示例�?
输入：在迷雾笼罩的古老森林中，一束晨曦穿透树叶，照亮了漂浮的萤火�?
输出：A serene ancient forest shrouded in mist, morning light piercing through leaves, illuminating floating fireflies, ethereal atmosphere, peaceful mood, cinematic composition, soft focus

输入：八重神子和她的男朋友在接吻
输出：Yae Miko (Genshin Impact character with pink hair and fox ears) kissing with her boyfriend, romantic scene, both characters in frame, close-up view, warm lighting, intimate atmosphere` 
      },
      { 
        role: 'user' as const, 
        content: `翻译以下中文梦境描述为英文（只输出英文）：\n\n${chinesePrompt}` 
      }
    ];

    // 添加延迟降低API调用速率
    await delay(200);

    const response = await invokeQwen(messages, {
      model: 'qwen3.5 9b',
      temperature: 0.5, // 适度创造性，允许AI识别角色
    });
    
    let translated = response.content.trim();
    
    // 清理输出：移除可能的引号、前后空�?
    translated = translated.replace(/^["']|["']$/g, '').trim();
    
    // 如果翻译失败或返回空，使用原文（SD 也可以处理一些中文）
    if (!translated || translated === chinesePrompt) {
      console.warn('[翻译] 翻译失败或无变化，使用原文');
      return chinesePrompt;
    }
    
    console.log('[翻译] 中文->英文:', chinesePrompt.substring(0, 30) + '...', '=>', translated.substring(0, 50) + '...');
    return translated;
  } catch (error) {
    console.error('[翻译] 翻译API错误:', error);
    // 翻译失败时返回原�?
    return chinesePrompt;
  }
}

// 文本润色函数（千�?qwen3.5-9b�? 支持会话历史关联
async function polishPrompt(
  prompt: string, 
  customHeaders?: Record<string, string>, 
  isImg2Img?: boolean,
  sessionHistory?: { prompt_history: Array<{ prompt: string; imageUrl?: string }>; image_history: string[]; image_count: number } | null,
  forceRealistic?: boolean // 强制写实风格
): Promise<string> {
  // 【强制写实】添加约束，禁止二次元风�?
  const realisticConstraint = forceRealistic ? `\n\n【强制写实约�?- 绝对禁止】\n⚠️ 严格禁止添加以下任何二次�?卡�?动漫风格词汇！\n�?禁止：anime, manga, cartoon, comic, 2d, flat style, toon, cel shading, anime style, cartoon style, manga style\n�?禁止：anime girl, anime boy, anime character, anime scene, chibi, cute anime\n�?禁止：semi-realistic, 2.5d, illustration style, artbook style\n�?必须：photorealistic, realistic photography, real photo, natural lighting, realistic texture\n�?如果不确定风格，保持中性描述，不要添加任何风格限定词` : '';
  
  // 构建会话历史上下�?
  let contextHint = '';
  if (sessionHistory && sessionHistory.prompt_history.length > 0) {
    const previousPrompts = sessionHistory.prompt_history.map((h, i) => 
      `【已生成�?{i + 1}�? ${h.prompt}`
    ).join('\n');
    
    contextHint = `\n\n【重�?故事连贯性】这是梦境创作的延续。当前梦境已�?${sessionHistory.prompt_history.length} 张图片：
${previousPrompts}

【创作要求�?
1. 新图片必须与已有图片保持风格、色彩、氛围的一致�?
2. 如果有连续叙事需求（�?然后"�?接着"�?之后"），需要承接前面的画面自然过渡
3. 保持人物外貌、服装、场景元素的一致�?
4. 保持光线、色调的连贯（如第一张是黄昏，后面也应是黄昏或自然过渡到夜晚�?
5. 可以发展情节，但必须合理衔接`;
  }
  
  // 根据是否为图生图模式选择不同的提示词模板
  const basePrompt = isImg2Img ? IMG2IMG_POLISH_PROMPT : POLISH_PROMPT;
  const systemPrompt = basePrompt + contextHint + realisticConstraint;
  
  try {
    const client = new LLMClient(new Config(), customHeaders);
    
    const messages = [
      { role: 'system' as const, content: systemPrompt },
      { role: 'user' as const, content: prompt }
    ];

    // 添加延迟降低API调用速率
    await delay(200);

    const response = await client.invoke(messages, {
      model: 'qwen3.5-9b',
      temperature: 0.7,
    });
    
    let polished = response.content.trim();
    
    // 【强制写实】润色后再次清理二次元词�?
    if (forceRealistic) {
      // 需要清理的二次元相关词�?
      const animeKeywordsToRemove = [
        'anime style', 'anime art', 'anime girl', 'anime boy', 'anime character', 'anime scene',
        'manga style', 'manga art', 'cartoon style', 'cartoon art',
        '2d style', 'flat style', 'toon', 'cel shading',
        'chibi', 'semi-realistic', '2.5d',
        'illustration style', 'artbook style', 'comic style',
      ];
      
      let cleanedPrompt = polished;
      animeKeywordsToRemove.forEach(keyword => {
        const regex = new RegExp(`[,;\\s]*${keyword}[,;\\s]*`, 'gi');
        cleanedPrompt = cleanedPrompt.replace(regex, ', ');
      });
      
      // 清理多余逗号和空�?
      cleanedPrompt = cleanedPrompt.replace(/,\\s*,/g, ',').replace(/^,\\s*/, '').replace(/,\\s*$/, '').trim();
      
      if (cleanedPrompt !== polished) {
        console.log(`[润色] 写实模式：已清理二次元词汇`);
        console.log(`[润色] 清理�? ${polished.substring(0, 100)}...`);
        console.log(`[润色] 清理�? ${cleanedPrompt.substring(0, 100)}...`);
        polished = cleanedPrompt;
      }
    }
    
    console.log(`[润色] 会话关联: ${sessionHistory?.prompt_history.length || 0} 张历史图片`);
    console.log(`[润色] 强制写实: ${forceRealistic ? '�?�? : '�?}`);
    return polished;
  } catch (error) {
    console.error('[润色] 千问API润色失败:', error);
    return prompt;
  }
}

// 仅SD生成（不上传），返回base64
async function generateImageSDOnly(
  prompt: string, 
  finalArtStyle?: string,
  userInput?: string,
  selectedKeywords?: string[],
  customHeaders?: Record<string, string>
): Promise<{ base64Image: string; modelName: string; instanceName: string }> {
  // 【核心优化】使用智能路由，直接选择固定模型实例
  const targetArtStyle = finalArtStyle === 'default' || !finalArtStyle ? 'dreamy' : finalArtStyle;
  const selectedInstance = await selectSDInstanceByStyle(targetArtStyle);
  const sdApiUrl = selectedInstance.url;
  
  // 直接使用实例的固定模型（无需切换！）
  const modelConfig = {
    modelName: selectedInstance.fixedModelName,
    modelFile: selectedInstance.fixedModelFile
  };
  
  console.log(`[生图] 🚀 智能路由: ${selectedInstance.name} (${selectedInstance.fixedModelName})`);
  console.log(`[生图] 📍 API URL: ${sdApiUrl}`);
  console.log(`[生图] �?无需切换模型，直接生成！`);
  
  // ============================================
  // ⚠️  重要：场景识别与处理逻辑 - 请勿轻易修改�?
  // 如需修改，请先询问用�?
  // ============================================
  
  // �?】二次元场景识别关键�?- 严格限制�?
  // 除非明确提到二次元角色或用户要求，否则不使用二次�?
  const ANIME_DETECTION_KEYWORDS = [
    // ============== 只有明确二次元角色才触发 ==============
    
    // 特定角色 - 原神
    'yae miko', 'raiden shogun', 'nahida', 'furina', 'nilou', 'kokomi',
    '八重神子', '雷电将军', '纳西�?, '芙宁�?, '妮露', '珊瑚宫心�?,
    'zhongli', 'venti', 'xiao', 'ganyu', 'ayaka', 'hutao',
    '钟离', '温迪', '�?, '甘雨', '神里绫华', '胡桃',
    'kazuha', 'scaramouche', 'wanderer', 'childe',
    '枫原万叶', '散兵', '流浪�?, '达达利亚',
    
    // 特定角色 - 其他游戏/动漫
    'kasugano sora', '春日野穹',
    'hatsune miku', '初音未来',
    'rem', 'ram', 're:zero', '蕾姆', '拉姆',
    'zero two', '02', 'darling in the franxx',
    'mai sakurajima', '樱岛麻衣',
    
    // ============== 用户明确要求二次�?==============
    'anime style', '动漫风格', '二次元风�?,
    'anime art', '动漫艺术',
    'manga style', '漫画风格',
    
    // ============== 特定二次元游�?==============
    'genshin impact', '原神',
  ];
  
  // �?】写实场景识别关键词 - 用于判断是否需要写实风格处�?
  const REALISTIC_DETECTION_KEYWORDS = [
    // 写实风格关键�?
    'realistic', '写实', 'real', '真实',
    'photorealistic', '照片�?, 'photo', '照片',
    'photography', '摄影', 'camera', '相机',
    'realistic style', '写实风格',
    'photorealistic style', '照片级风�?,
    
    // 真实人物相关
    'real person', '真实人物', 'real man', '真实男人',
    'real woman', '真实女人', 'real boy', '真实男孩',
    'real girl', '真实女孩', 'actual person', '实际人物',
    'portrait', '人像', 'portrait photo', '人像摄影',
    'headshot', '头像', 'facial portrait', '面部肖像',
    
    // 真实场景
    'real scene', '真实场景', 'real world', '真实世界',
